{
  "name": "@ruixutong.manee/maneeagent-framework",
  "version": "1.0.0",
  "description": "Node.js AI agent framework.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "keywords": [
    "agent",
    "ai-agent",
    "llm",
    "openai",
    "tool-calling",
    "typescript",
    "decorators",
    "zod"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run build"
  },
  "dependencies": {
    "openai": "^6.38.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  }
}